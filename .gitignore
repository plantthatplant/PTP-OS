# ════════════════════════════ PTP OS ════════════════════════════
# Policy: only source code and documentation are version-controlled. Everything
# generated at runtime, every machine-local setting, and all caches are ignored.
# NOTE: git only treats '#' as a comment at the START of a line, so every rule is
# explained on its own comment line ABOVE it — never inline.

# --- Python cache (regenerated on every run; machine/version specific) ---
# Compiled-bytecode directories — pure build output, never source.
__pycache__/
# .pyc/.pyo/.pyd compiled modules.
*.py[cod]
# Jython class files.
*$py.class
# Packaging metadata generated by setuptools.
*.egg-info/

# --- Tooling caches (created by test/lint tools; not source) ---
# pytest run cache.
.pytest_cache/
# mypy type-check cache.
.mypy_cache/
# ruff lint cache.
.ruff_cache/
# coverage.py data file and HTML report.
.coverage
htmlcov/

# --- Virtual environments (local, large, per-machine; never shared) ---
.venv/
venv/

# --- Collector runtime output (generated by `collector/collect.py`) ---
# Published snapshots (latest.json), history/, and quarantine/ — live data, not source.
# (data/README.md is NOT ignored, so the directory stays documented.)
/data/inbox/
# Reserved for any future outbound artifacts — runtime.
/data/outbox/
# Collection logs (collector-YYYYMMDD.jsonl) — runtime records.
/data/logs/

# --- Greenhouse Brain runtime state and captured data (generated by app/) ---
# feedback.jsonl, experiments, memories, answers — runtime, not source.
app/data/
# Transient morning-analysis cache.
app/.state/

# --- Logs (any stray log files, anywhere) ---
# Plain logs (the collector's own logs are .jsonl under /data/logs/).
*.log
# Append-only run/event logs are runtime records, not source.
*.jsonl

# --- Local Claude Code configuration (machine-specific) ---
# The shared, committed config is .claude/settings.json; the *.local.* variants are
# per-machine and must never be shared.
.claude/settings.local.json
.claude/*.local.json

# --- Temporary, backup, and OS/editor cruft (never belongs in the repo) ---
# Temp files.
*.tmp
# Editor/backup copies.
*.bak
*~
# macOS Finder metadata.
.DS_Store
# Windows Explorer thumbnail cache.
Thumbs.db
# Windows per-folder settings.
desktop.ini

# Even Hub package artifacts
*.ehpk
