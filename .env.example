# Gaia API — secrets & config.  Copy to .env (git-ignored), fill in, then start the server:
#     cp .env.example .env   →   paste your keys into .env   →   python3 -m api.run
# Real environment variables always override this file. NEVER commit .env or put keys in code.

# The API key clients send as `Authorization: Bearer` / `X-API-Key` (use a strong value in prod).
GAIA_API_KEY=gaia-dev-key

# Talk to Gaia (POST /api/v1/ask) — server-side only, never in a client bundle.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: a lower-latency Claude model for the glasses round-trip.
# GAIA_ANSWER_MODEL=claude-sonnet-4-6

# Optional: production browser-origin allowlist (Lovable + Even Hub origins), comma-separated.
# GAIA_CORS_ORIGINS=https://your-lovable-app.example,https://hub.evenrealities.com

# Optional: data source for scheduled collection (mock today; point at the real Synopta export).
# GAIA_SOURCE=drop-folder
# GAIA_DROP_PATH=/path/to/synopta/export
