# Copy to .env.local. All values are optional — the defaults target a local Gaia API via the
# Vite dev proxy, so the app runs out of the box for development.

# Gaia API base the app calls. Leave as /gaia in dev (Vite proxies it server-side, no CORS).
# For a packed/hosted build, set this to the hosted Gaia API URL (https).
VITE_GAIA_API_URL=/gaia

# Sent as `Authorization: Bearer <key>` to the Gaia API. Matches the API's GAIA_API_KEY.
VITE_GAIA_API_KEY=gaia-dev-key

# Dev only: where the /gaia proxy forwards to (the local Gaia API). See vite.config.ts.
GAIA_API_TARGET=http://127.0.0.1:8000
