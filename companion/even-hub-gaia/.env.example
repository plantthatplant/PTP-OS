# Copy to .env.local and fill in. These select WHICH Gaia instance (nursery) the glasses show.
# In v1 this is one configured instance; the full Connection Manager (many nurseries) comes later.

# The Gaia API base URL. Local PC default: http://127.0.0.1:8000
VITE_GAIA_API_URL=http://127.0.0.1:8000

# The Gaia API key (set a real one in production; the dev default is gaia-dev-key).
VITE_GAIA_API_KEY=gaia-dev-key

# How often to ask Gaia for its current thought, in seconds. Courteous by default.
VITE_GAIA_POLL_SECONDS=45
